<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { pageTitle: '' }) %>
  </head>
  <body>
    <%- include('partials/header', { navActive: 'home' }) %>

    <main class="page-main">
      <section class="hero">
        <span class="hero-badge">League of Legends · Fan tool</span>
        <h1>Should <i>you</i> <em>dodge</em>?</h1>
        <p class="hero-lead">
          Compare ally and enemy team compositions using approximate champion win rates—no account, no install.
        </p>
        <ul class="hero-features">
          <li>5v5 comp comparison</li>
          <li>Win-rate based suggestion</li>
          <li>YouTube champion guides</li>
        </ul>

        <div class="hero-cards">
          <article class="hero-card hero-card--ally">
            <div class="hero-card-icon" aria-hidden="true">⚔</div>
            <h2>Dodge calculator</h2>
            <p>
              Pick both teams in champ select and see which side has the better average win rate—and whether dodging is worth considering.
            </p>
            <a href="/dodgeCalculator" class="btn btn--block">Open calculator</a>
          </article>

          <article class="hero-card hero-card--guides">
            <div class="hero-card-icon" aria-hidden="true">▶</div>
            <h2>Champion guides</h2>
            <p>
              Not sure how to play your pick? Search for a champion and watch a quick YouTube guide before you lock in.
            </p>
            <a href="/championPage" class="btn btn--secondary btn--block">Browse guides</a>
          </article>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
