<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { pageTitle: champion + ' guide' }) %>
  </head>
  <body>
    <%- include('partials/header', { navActive: 'guides' }) %>

    <main class="page-main page-main--wide">
      <div class="page-intro">
        <h1>Guide for <%= champion %></h1>
      </div>

      <div class="card card--video">
        <div class="video-wrap">
          <iframe
            src="<%= videoUrl %>"
            title="YouTube video player — <%= champion %> guide"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>

        <div class="form-footer-links">
          <a href="/championPage" class="btn">Search another champion</a>
          <a href="/dodgeCalculator" class="btn btn--secondary">Dodge calculator</a>
          <a href="/" class="btn btn--secondary">Back to home</a>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
