<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { pageTitle: 'Champion guides' }) %>
  </head>
  <body>
    <%- include('partials/header', { navActive: 'guides' }) %>

    <main class="page-main">
      <div class="page-intro">
        <h1>Champion guides</h1>
        <p>Pick a champion and we'll find a YouTube guide for you.</p>
      </div>

      <%- include('partials/championDataNotice') %>

      <form class="card card--centered" action="/generateVideo" method="post">
        <div class="champion-select-single">
          <%- include('partials/championAutocompleteField', {
            id: 'targetChamp',
            name: 'targetChamp',
            label: 'Champion',
          }) %>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn">Search for guide</button>
          <div class="form-footer-links">
            <a href="/dodgeCalculator" class="btn btn--secondary">Dodge calculator</a>
            <a href="/" class="btn btn--secondary">Back to home</a>
          </div>
        </div>
      </form>
    </main>

    <%- include('partials/footer') %>
    <%- include('partials/championAutocompleteSetup') %>
  </body>
</html>
