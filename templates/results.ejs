<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { pageTitle: 'Results' }) %>
  </head>
  <body>
    <%- include('partials/header', { navActive: 'calculator' }) %>

    <main class="page-main">
      <div class="page-intro">
        <h1>Matchup Result</h1>
        <p>Average win rates across each five-champion team.</p>
      </div>

      <div class="card card--results">
        <div class="result-stats">
          <div class="stat-block stat-block--ally">
            <p class="stat-label">Ally team</p>
            <p class="stat-value"><%= Number(winrate).toFixed(1) %>%</p>
          </div>
          <div class="stat-block stat-block--enemy">
            <p class="stat-label">Enemy team</p>
            <p class="stat-value"><%= Number(ewinrate).toFixed(1) %>%</p>
          </div>
        </div>

        <% const outcome = locals.verdict || 'even'; %>
        <% if (outcome === 'favorable') { %>
        <p class="verdict verdict--favorable">Your team has better odds of winning. Do not dodge.</p>
        <% } else if (outcome === 'dodge') { %>
        <p class="verdict verdict--dodge">Enemy team has better odds of winning. Consider dodging.</p>
        <% } else { %>
        <p class="verdict verdict--even">Both teams have an equal chance of winning. Good luck—you'll need it.</p>
        <% } %>

        <div class="form-footer-links">
          <a href="/dodgeCalculator" class="btn">Try another composition</a>
          <a href="/" class="btn btn--secondary">Back to home</a>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
