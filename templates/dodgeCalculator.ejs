<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { pageTitle: 'Dodge calculator' }) %>
  </head>
  <body>
    <%- include('partials/header', { navActive: 'calculator' }) %>

    <main class="page-main page-main--wide">
      <div class="page-intro">
        <h1>Dodge calculator</h1>
        <p>Pick your team and the enemy comp—we'll compare average win rates.</p>
      </div>

      <%- include('partials/championDataNotice') %>

      <form class="card card--form" action="/results" method="post">
        <div class="team-picker">
          <div class="team-column team-column--ally">
            <h2>Ally team</h2>
            <div class="field">
              <label for="top">Top</label>
              <select id="top" name="top" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="jungler">Jungler</label>
              <select id="jungler" name="jungler" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="mid">Mid</label>
              <select id="mid" name="mid" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="bot">Bot</label>
              <select id="bot" name="bot" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="support">Support</label>
              <select id="support" name="support" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="team-column team-column--enemy">
            <h2>Enemy team</h2>
            <div class="field">
              <label for="etop">Top</label>
              <select id="etop" name="etop" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="ejungler">Jungler</label>
              <select id="ejungler" name="ejungler" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="emid">Mid</label>
              <select id="emid" name="emid" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="ebot">Bot</label>
              <select id="ebot" name="ebot" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="esupport">Support</label>
              <select id="esupport" name="esupport" required>
                <option value="" disabled selected>Select a champion</option>
                <% champions.forEach(champion => { %>
                <option value="<%= champion.name %>"><%= champion.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn">Calculate</button>
          <p>Not sure how to play your champion? <a href="/championPage">Find a video guide</a></p>
          <div class="form-footer-links">
            <a href="/" class="btn btn--secondary">Back to home</a>
          </div>
        </div>
      </form>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
