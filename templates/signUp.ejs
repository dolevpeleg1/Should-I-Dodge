<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Should I Dodge?</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="login">
        <form class="loginForm" action="/signUp" method="post" onsubmit="return confirm('Create a new user?')">
            <h2>Sign Up</h2>
            <label for="userName">Username</label><input type="text" id="userName" name="userName" required><br>
            <label for="password">Password</label><input type="password" id="password" name="password" required><br>
            <label for="confirmPassword">Confirm Password</label><input type="password" id="confirmPassword" name="confirmPassword" required><br>
            <button type="submit">Sign Up</button>
            <a href="/"><h2>Return to login page</h2></a>
        </form>
    </div>
    <footer>Created by Dolev Peleg. Please note that this website was made as a fan project and is not associated with Riot Games&copy;.</footer>
</body>
</html>