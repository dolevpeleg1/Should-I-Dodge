# MongoDB Atlas — Connect → Drivers → copy connection string
# Replace <password> and ensure the database name in the URI matches MONGO_DATABASE_NAME (or omit path; we select DB in code).
MONGO_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Optional — defaults shown
MONGO_DATABASE_NAME=should_i_dodge
MONGO_COLLECTION_NAME=users

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key
